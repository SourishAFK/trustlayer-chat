# --- Chat generation (THIS app's own Gemini key — keep separate from TrustLayer's) ---
# Use a DIFFERENT Gemini key than the 4 keys TrustLayer's scorer uses, so chat
# traffic doesn't eat TrustLayer's quota or muddle billing.
GEMINI_API_KEY=your_separate_gemini_key_here

# gemini-2.0-flash has been 0-quota on the free tier across these projects, so the
# default here is the model that actually works. Override if your key has 2.0 quota.
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite

# --- TrustLayer integration (used in step 3, not yet) ---
TRUSTLAYER_API_URL=https://trustlayer-api-thcj.onrender.com
TRUSTLAYER_API_KEY=tl_your_chat_app_key_here
